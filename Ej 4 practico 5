#include <stdio.h>

int main() {
    int h1, m1, s1, h2, m2, s2, total1, total2, diff, rh, rm, rs;
    printf("Primer horario (HH MM SS): ");
    scanf("%d %d %d", &h1, &m1, &s1);
    printf("Segundo horario (HH MM SS): ");
    scanf("%d %d %d", &h2, &m2, &s2);

    total1 = h1 * 3600 + m1 * 60 + s1;
    total2 = h2 * 3600 + m2 * 60 + s2;
    diff = total2 - total1;

    rh = diff / 3600;
    rm = (diff % 3600) / 60;
    rs = diff % 60;

    printf("Tiempo transcurrido: %02d:%02d:%02d\n", rh, rm, rs);
    return 0;
}
