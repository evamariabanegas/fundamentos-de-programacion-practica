#include <stdio.h>
#include <math.h>

int main() {
    float a, b, c, disc, x1, x2;
    printf("Ingrese a, b y c: ");
    scanf("%f %f %f", &a, &b, &c);

    disc = b*b - 4*a*c;

    if (disc >= 0) {
        x1 = (-b + sqrt(disc)) / (2*a);
        x2 = (-b - sqrt(disc)) / (2*a);
        printf("x1 = %.2f, x2 = %.2f\n", x1, x2);
    } else {
        printf("No existen soluciones reales.\n");
    }
    return 0;
}
